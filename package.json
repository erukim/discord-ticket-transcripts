{
  "name": "discord-ticket-transcript",
  "version": "0.1.0",
  "description": "Discord ticket channel → single self-contained HTML file (with embedded JSON data). i18n, CDN-expiry-proof assets, context menus, Components V2 ready.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:dev": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.mjs\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.mjs\"",
    "prepublishOnly": "npm run build",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "peerDependencies": {
    "discord.js": "^14.0.0"
  },
  "dependencies": {
    "axios": "^1.7.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^18.0.0",
    "discord.js": "^14.25.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "javascript-obfuscator": "^4.1.1",
    "terser": "^5.31.0",
    "typescript": "^5.1.6",
    "typescript-eslint": "^8.15.0"
  },
  "keywords": [
    "discord",
    "discord.js",
    "ticket",
    "transcript",
    "html",
    "archive",
    "components-v2",
    "i18n"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/erukim/discord-ticket-transcripts.git"
  },
  "bugs": {
    "url": "https://github.com/erukim/discord-ticket-transcripts/issues"
  },
  "homepage": "https://github.com/erukim/discord-ticket-transcripts#readme",
  "engines": {
    "node": ">=16.9.0"
  },
  "license": "GPL-3.0"
}
